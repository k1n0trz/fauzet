{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"],
      "env": ["API_ORIGIN", "VERCEL"]
    },
    "dev": { "cache": false, "persistent": true },
    "lint": { "dependsOn": ["^lint"] },
    "typecheck": { "dependsOn": ["^typecheck"] },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": ["DATABASE_URL", "RUN_INTEGRATION", "SESSION_SECRET"]
    }
  }
}
