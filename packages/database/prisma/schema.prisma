generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  RESTRICTED
  SUSPENDED
  CLOSED
}

enum Role {
  USER
  SUPPORT
  CONTENT
  FRAUD
  FINANCE
  AUDITOR
  SUPERADMIN
  OWNER
}

enum LedgerAccountKind {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
  CONTRA
}

enum BalanceBucket {
  PENDING
  AVAILABLE
  PROMOTIONAL
  LOCKED
  ELIGIBLE
  RESERVED
  WITHDRAWN
}

enum LedgerTransactionStatus {
  PENDING
  POSTED
  REVERSED
  REJECTED
}

enum GameKind {
  TAP_MINER
  MEMORY_DROPS
}

enum GameSessionStatus {
  ACTIVE
  COMPLETED
  HELD
  REJECTED
  EXPIRED
  ABORTED
}

model User {
  id                      String                   @id @default(uuid())
  email                   String                   @unique
  passwordHash            String
  displayName             String?
  locale                  String                   @default("es")
  countryCode             String?
  status                  UserStatus               @default(PENDING_VERIFICATION)
  riskLevel               Int                      @default(0)
  credentialVersion       Int                      @default(1)
  emailVerifiedAt         DateTime?
  acceptedTermsAt         DateTime
  adultDeclaredAt         DateTime
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  sessions                Session[]
  roles                   UserRole[]
  accounts                LedgerAccount[]
  faucetChallenges        FaucetChallenge[]
  faucetClaims            FaucetClaim[]
  gameEnergy              GameEnergy?
  gameSessions            GameSession[]
  missionClaims           MissionClaim[]
  auditEvents             AuditEvent[]             @relation("AuditActor")
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Session {
  id                String    @id @default(uuid())
  userId            String
  tokenHash         String    @unique
  deviceId          String?
  ipHash            String?
  credentialVersion Int       @default(1)
  expiresAt         DateTime
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model UserRole {
  userId    String
  role      Role
  grantedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, role])
}

model LedgerAccount {
  id            String            @id @default(uuid())
  code          String            @unique
  name          String
  kind          LedgerAccountKind
  asset         String
  bucket        BalanceBucket?
  userId        String?
  active        Boolean           @default(true)
  allowNegative Boolean           @default(false)
  createdAt     DateTime          @default(now())
  user          User?             @relation(fields: [userId], references: [id], onDelete: Restrict)
  postings      LedgerPosting[]

  @@unique([userId, asset, bucket])
  @@index([userId, asset, bucket])
}

model LedgerTransaction {
  id             String                  @id @default(uuid())
  idempotencyKey String                  @unique
  type           String
  sourceType     String
  sourceId       String
  status         LedgerTransactionStatus @default(PENDING)
  configVersion  Int
  metadata       Json                    @default("{}")
  postedAt       DateTime?
  reversedById   String?                 @unique
  createdAt      DateTime                @default(now())
  postings       LedgerPosting[]
  reversedBy     LedgerTransaction?      @relation("Reversal", fields: [reversedById], references: [id])
  reverses       LedgerTransaction?      @relation("Reversal")
  config         EconomicConfigVersion   @relation(fields: [configVersion], references: [id], onDelete: Restrict)
  faucetClaim    FaucetClaim?
  gameSession    GameSession?
  missionClaim   MissionClaim?

  @@unique([sourceType, sourceId, type])
}

model LedgerPosting {
  id            String            @id @default(uuid())
  transactionId String
  accountId     String
  amount        Decimal           @db.Decimal(36, 0)
  balanceAfter  Decimal?          @db.Decimal(36, 0)
  createdAt     DateTime          @default(now())
  transaction   LedgerTransaction @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  account       LedgerAccount     @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([accountId, createdAt])
}

model EconomicConfigVersion {
  id            Int                 @id @default(autoincrement())
  status        String              @default("DRAFT")
  parameters    Json
  reason        String
  createdById   String
  approvedById  String?
  effectiveAt   DateTime?
  createdAt     DateTime            @default(now())
  transactions  LedgerTransaction[]
  faucetClaims  FaucetClaim[]
  gameEnergy    GameEnergy[]
  gameSessions  GameSession[]
  missionClaims MissionClaim[]
}

model FaucetChallenge {
  id         String       @id @default(uuid())
  userId     String
  status     String       @default("ISSUED")
  expiresAt  DateTime
  consumedAt DateTime?
  ipHash     String
  deviceId   String?
  createdAt  DateTime     @default(now())
  user       User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  claim      FaucetClaim?

  @@index([userId, status, expiresAt])
}

model FaucetClaim {
  id             String                @id @default(uuid())
  userId         String
  challengeId    String                @unique
  idempotencyKey String                @unique
  rewardMinor    Decimal               @db.Decimal(36, 0)
  status         String
  ruleVersion    Int
  budgetDate     DateTime              @db.Date
  streakDays     Int                   @default(1)
  bonusPercent   Int                   @default(0)
  nextClaimAt    DateTime
  transactionId  String?               @unique
  ipHash         String?
  deviceId       String?
  createdAt      DateTime              @default(now())
  user           User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  challenge      FaucetChallenge       @relation(fields: [challengeId], references: [id], onDelete: Restrict)
  transaction    LedgerTransaction?    @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  config         EconomicConfigVersion @relation(fields: [ruleVersion], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@index([userId, budgetDate, status])
  @@index([ruleVersion, budgetDate, status])
  @@index([budgetDate, status])
  @@index([deviceId, budgetDate, status])
  @@index([ipHash, budgetDate, status])
}

model GameEnergy {
  userId        String                @id
  current       Int
  regeneratedAt DateTime
  ruleVersion   Int
  updatedAt     DateTime              @updatedAt
  user          User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  config        EconomicConfigVersion @relation(fields: [ruleVersion], references: [id], onDelete: Restrict)
}

model GameSession {
  id            String                @id @default(uuid())
  userId        String
  game          GameKind
  status        GameSessionStatus     @default(ACTIVE)
  creationKey   String                @unique
  completionKey String?               @unique
  nonce         String                @unique
  tokenHash     String                @unique
  ruleVersion   Int
  budgetDate    DateTime              @db.Date
  energyCost    Int
  nextSequence  Int                   @default(1)
  lastEventAtMs Int                   @default(-1)
  eventCount    Int                   @default(0)
  score         Int                   @default(0)
  state         Json                  @default("{}")
  layout        Json?
  rewardMinor   Decimal?              @db.Decimal(36, 0)
  transactionId String?               @unique
  reasonCode    String?
  deviceId      String
  ipHash        String
  startedAt     DateTime
  expiresAt     DateTime
  completedAt   DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  user          User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  config        EconomicConfigVersion @relation(fields: [ruleVersion], references: [id], onDelete: Restrict)
  transaction   LedgerTransaction?    @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  events        GameEvent[]

  @@index([userId, game, budgetDate, status])
  @@index([deviceId, budgetDate, status])
  @@index([ipHash, budgetDate, status])
  @@index([budgetDate, status])
}

model GameEvent {
  id         String      @id @default(uuid())
  sessionId  String
  sequence   Int
  eventId    String
  type       String
  atMs       Int
  payload    Json        @default("{}")
  acceptedAt DateTime    @default(now())
  session    GameSession @relation(fields: [sessionId], references: [id], onDelete: Restrict)

  @@unique([sessionId, sequence])
  @@unique([sessionId, eventId])
  @@index([sessionId, acceptedAt])
}

model MissionClaim {
  id             String                @id @default(uuid())
  userId         String
  missionId      String
  periodKey      String
  idempotencyKey String                @unique
  status         String
  progress       Decimal               @db.Decimal(36, 0)
  target         Decimal               @db.Decimal(36, 0)
  rewardMinor    Decimal               @db.Decimal(36, 0)
  ruleVersion    Int
  transactionId  String?               @unique
  createdAt      DateTime              @default(now())
  user           User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  config         EconomicConfigVersion @relation(fields: [ruleVersion], references: [id], onDelete: Restrict)
  transaction    LedgerTransaction?    @relation(fields: [transactionId], references: [id], onDelete: Restrict)

  @@unique([userId, missionId, periodKey])
  @@index([ruleVersion, periodKey, status])
}

model AuditEvent {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  targetType String
  targetId   String
  reason     String?
  before     Json?
  after      Json?
  requestId  String
  ipHash     String?
  createdAt  DateTime @default(now())
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([targetType, targetId, createdAt])
}

model IdempotencyRecord {
  key          String   @id
  scope        String
  requestHash  String
  responseCode Int?
  responseBody Json?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}
