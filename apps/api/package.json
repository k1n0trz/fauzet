{
  "name": "@fauzet/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--conditions=development tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "mining:settle": "tsx src/scripts/settle-mining.ts",
    "referrals:release": "tsx src/scripts/release-referrals.ts"
  },
  "dependencies": {
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "11.0.1",
    "@fastify/helmet": "13.0.1",
    "@fastify/rate-limit": "10.2.1",
    "@fauzet/contracts": "workspace:*",
    "@fauzet/database": "workspace:*",
    "fastify": "5.10.0",
    "nodemailer": "9.0.3",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@types/node": "22.14.1",
    "@types/nodemailer": "6.4.17",
    "tsx": "4.19.3",
    "vitest": "3.2.7"
  }
}
